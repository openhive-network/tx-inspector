{
  "name": "transaction-inspector",
  "version": "0.0.1",
  "license": "Private",
  "private": true,
  "description": "Transaction inspector: Check your transaction in easy and fast way",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "build:test": "tsc -p ./configs/tsconfig-tests.json",
    "postbuild:test": "rollup -c ./__tests__/rollup.config.js",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && husky",
    "lint": "eslint . --fix",
    "pretest": "playwright install chromium",
    "test": "playwright test --workers 1 --max-failures 1 --project=tx_inspector_testsuite --project=tx_inspector_multiple_signature --project=tx_inspector_delegated_authority --project=tx_inspector_non_default_weights --project=tx_inspector_multiple_signature_non_default_weights --project=tx_inspector_each_signature_satisfies_alone_non_default_weights --project=tx_inspector_signatures_together_can_satisfy_non_default_weights"
  },
  "dependencies": {
    "@hiveio/component-binary-view": "^0.2.0",
    "@hiveio/wax": "1.27.6-rc5-stable.241028191117",
    "@pinia/nuxt": "^0.5.1",
    "@radix-icons/vue": "^1.0.0",
    "@vueuse/core": "^10.11.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "moment": "^2.30.1",
    "nuxt": "^3.13.2",
    "pinia": "^2.1.7",
    "radix-vue": "^1.8.3",
    "shadcn-nuxt": "^0.10.4",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "vue": "^3.5.12",
    "vue-router": "^4.3.2",
    "vue-sonner": "^1.1.5",
    "vuetify": "^3.6.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@mdi/font": "^7.4.47",
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@nuxtjs/tailwindcss": "^6.12.0",
    "@playwright/test": "^1.47.2",
    "@rollup/plugin-alias": "^5.1.0",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-replace": "^5.0.5",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/node": "^18.16.0",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "@vue/devtools-api": "6.6.3",
    "eslint": "^8.57.0",
    "eslint-plugin-nuxt": "^4.0.0",
    "eslint-plugin-vue": "^9.26.0",
    "http-server": "^14.1.1",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.5",
    "playwright": "^1.47.2",
    "rollup": "^4.23.0",
    "rollup-plugin-bundle-imports": "^1.5.1",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-node-builtins": "^2.1.2",
    "typescript": "5.5.4",
    "vue-tsc": "^1.7.0"
  }
}
